  "keywords": [
    "koishi",
    "plugin",
    "koishi-plugin",
    "esp32",
    "esp32s3",
    "galaku",
    "serial",
    "ble"
  ],
  "license": "MIT",
  "author": "xiaoyu",
  "homepage": "https://github.com/ra1nyxin/koishi-plugin-esp32-to-galaku#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ra1nyxin/koishi-plugin-esp32-to-galaku.git"
  },
  "bugs": {
    "url": "https://github.com/ra1nyxin/koishi-plugin-esp32-to-galaku/issues"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib",
    "tools",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test test/*.mjs",
    "prepare": "npm run build",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "koishi": ">=4.16.0 <5"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "koishi": "^4.18.8",
    "typescript": "^5.8.3"
  },
  "koishi": {
    "description": {
      "zh-CN": "通过PowerShell串口桥把Koishi命令转发到ESP32S3再由ESP32S3控制GALAKU设备实现让群友控制我的跳蛋或其他小玩具",
      "en-US": "Relays Koishi chat commands through a PowerShell serial bridge to an ESP32-S3, letting trusted users control a GALAKU toy."
    },
    "service": {
      "required": []
    }
  },
  "engines": {
    "node": ">=20"
  }
